<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- 색상 정의 -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <!-- ============ 베이스 ============ -->
<link name="base_link">

  <visual>
    <geometry>
      <cylinder radius="0.05" length="0.05"/>
    </geometry>
    <material name="gray"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.05" length="0.05"/>
    </geometry>
  </collision>

  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="1.0"/>
    <inertia ixx="0.005" ixy="0" ixz="0"
             iyy="0.005" iyz="0"
             izz="0.005"/>
  </inertial>

</link>

  <!-- Joint 1: 베이스 좌우 회전 (Z축) -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 1: 베이스~어깨 연결 ============ -->
<link name="link_1">

  <visual>
    <geometry>
      <cylinder radius="0.03" length="0.1"/>
    </geometry>
    <origin xyz="0 0 0.05"/>
    <material name="blue"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.03" length="0.1"/>
    </geometry>
    <origin xyz="0 0 0.05"/>
  </collision>

  <inertial>
    <origin xyz="0 0 0.05"/>
    <mass value="0.4"/>
    <inertia ixx="0.001" ixy="0" ixz="0"
             iyy="0.001" iyz="0"
             izz="0.001"/>
  </inertial>

</link>
  <!-- Joint 2: 어깨 상하 회전 (Y축) -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 2: 상완 (윗팔) ============ -->
<link name="link_2">

  <visual>
    <geometry>
      <cylinder radius="0.025" length="0.2"/>
    </geometry>
    <origin xyz="0 0 0.1"/>
    <material name="orange"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.025" length="0.2"/>
    </geometry>
    <origin xyz="0 0 0.1"/>
  </collision>

  <inertial>
    <origin xyz="0 0 0.1"/>
    <mass value="0.4"/>
    <inertia ixx="0.001" ixy="0" ixz="0"
             iyy="0.001" iyz="0"
             izz="0.001"/>
  </inertial>

</link>
  <!-- Joint 3: 팔꿈치 상하 회전 (Y축) -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 3: 전완 (아랫팔) ============ -->
<link name="link_3">

  <visual>
    <geometry>
      <cylinder radius="0.02" length="0.15"/>
    </geometry>
    <origin xyz="0 0 0.075"/>
    <material name="blue"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.02" length="0.15"/>
    </geometry>
    <origin xyz="0 0 0.075"/>
  </collision>

  <inertial>
    <origin xyz="0 0 0.075"/>
    <mass value="0.3"/>
    <inertia ixx="0.0008" ixy="0" ixz="0"
             iyy="0.0008" iyz="0"
             izz="0.0008"/>
  </inertial>

</link>
  <!-- Joint 4: 손목 상하 회전 (Y축) -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 4: 손목 ============ -->
<link name="link_4">

  <visual>
    <geometry>
      <cylinder radius="0.015" length="0.05"/>
    </geometry>
    <origin xyz="0 0 0.025"/>
    <material name="orange"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.015" length="0.05"/>
    </geometry>
    <origin xyz="0 0 0.025"/>
  </collision>

  <inertial>
    <origin xyz="0 0 0.025"/>
    <mass value="0.2"/>
    <inertia ixx="0.0005" ixy="0" ixz="0"
             iyy="0.0005" iyz="0"
             izz="0.0005"/>
  </inertial>

</link>
  <!-- Joint 5: 손목 비틀기 (Z축) -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 5: 엔드이펙터 (그리퍼 자리) ============ -->
<link name="link_5">

  <visual>
    <geometry>
      <box size="0.04 0.04 0.02"/>
    </geometry>
    <origin xyz="0 0 0.01"/>
    <material name="gray"/>
  </visual>

  <collision>
    <geometry>
      <box size="0.04 0.04 0.02"/>
    </geometry>
    <origin xyz="0 0 0.01"/>
  </collision>

  <inertial>
    <origin xyz="0 0 0.01"/>
    <mass value="0.15"/>
    <inertia ixx="0.0002" ixy="0" ixz="0"
             iyy="0.0002" iyz="0"
             izz="0.0002"/>
  </inertial>

</link>

<!-- Joint 6: 손목 회전 (Roll, X축) -->

<!-- Joint 6: 손목 회전 (Roll, X축) -->
<joint name="joint_6" type="revolute">
  <parent link="link_5"/>
  <child link="link_6"/>
  <origin xyz="0 0 0.02" rpy="0 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
</joint>

<link name="link_6">

  <visual>
    <geometry>
      <cylinder radius="0.01" length="0.06"/>
    </geometry>
    <origin xyz="0.03 0 0" rpy="0 1.5708 0"/>
    <material name="gray"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.01" length="0.06"/>
    </geometry>
    <origin xyz="0.03 0 0" rpy="0 1.5708 0"/>
  </collision>

  <inertial>
    <origin xyz="0.03 0 0" rpy="0 0 0"/>
    <mass value="0.1"/>
    <inertia ixx="0.0001" ixy="0" ixz="0"
             iyy="0.0001" iyz="0"
             izz="0.0001"/>
  </inertial>

</link>

  <!-- ============ Gripper Base ============ -->
  <joint name="gripper_mount" type="fixed">
    <parent link="link_6"/>
    <child link="gripper_base"/>
    <origin xyz="0.06 0 0" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ============ Left Finger ============ -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0.02 0.015 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.02" effort="10" velocity="0.02"/>
  </joint>

  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.01 0.04 0.01"/>
      </geometry>
      <origin xyz="0 0.02 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.04 0.01"/>
      </geometry>
      <origin xyz="0 0.02 0" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ============ Right Finger ============ -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0.02 -0.015 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.02" effort="10" velocity="0.02"/>
  </joint>

  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.01 0.04 0.01"/>
      </geometry>
      <origin xyz="0 -0.02 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.04 0.01"/>
      </geometry>
      <origin xyz="0 -0.02 0" rpy="0 0 0"/>
    </collision>
  </link>
</robot>
