<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- 색상 정의 -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <!-- ============ 베이스 ============ -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- Joint 1: 베이스 좌우 회전 (Z축) -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 1: 베이스~어깨 연결 ============ -->
  <link name="link_1">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0.05"/>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Joint 2: 어깨 상하 회전 (Y축) -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 2: 상완 (윗팔) ============ -->
  <link name="link_2">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.2"/>
      </geometry>
      <origin xyz="0 0 0.1"/>
      <material name="orange"/>
    </visual>
  </link>

  <!-- Joint 3: 팔꿈치 상하 회전 (Y축) -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 3: 전완 (아랫팔) ============ -->
  <link name="link_3">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.15"/>
      </geometry>
      <origin xyz="0 0 0.075"/>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Joint 4: 손목 상하 회전 (Y축) -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 4: 손목 ============ -->
  <link name="link_4">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
      <material name="orange"/>
    </visual>
  </link>

  <!-- Joint 5: 손목 비틀기 (Z축) -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- ============ Link 5: 엔드이펙터 (그리퍼 자리) ============ -->
  <link name="link_5">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0.01"/>
      <material name="gray"/>
    </visual>
  </link>

</robot>